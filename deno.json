{
	"tasks": {
		"dev": "deno run -A --unstable-kv main.js",
		"build:mac": "deno compile --target aarch64-apple-darwin --output build/mac-aarch64/gityai --allow-read --allow-write --allow-net --allow-env --allow-run --unstable-kv main.js",
		"build:linux:aarch64": "deno compile --target aarch64-unknown-linux-gnu --output build/linux-aarch64/gityai --allow-read --allow-write --allow-net --allow-env --allow-run --unstable-kv main.js",
		"build:linux:x86_64": "deno compile --target x86_64-unknown-linux-gnu --output build/linux-x86_64/gityai --allow-read --allow-write --allow-net --allow-env --allow-run --unstable-kv main.js",
		"build:windows": "deno compile --target x86_64-pc-windows-msvc --output build/windows-x86_64/gityai --allow-read --allow-write --allow-net --allow-env --allow-run --unstable-kv main.js"
	},
	"imports": {
		"@std/assert": "jsr:@std/assert@1"
	},
	"fmt": {
		"exclude": ["GityAI"],
		"useTabs": true,
		"indentWidth": 4
	}
}
